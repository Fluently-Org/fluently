{
  "name": "fluently-mcp-server",
  "version": "0.3.2",
  "description": "MCP server for the Fluently framework. Exposes knowledge retrieval and contribution tools so any AI agent (Claude, GPT, Gemini, Mistral, Copilot…) can find, reason over, and extend Fluently cycles.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fluently-mcp-server": "dist/bin.js"
  },
  "files": [
    "dist",
    "knowledge",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit && node build.mjs",
    "start": "node dist/bin.js",
    "test": "vitest"
  },
  "devDependencies": {
    "fluently-scorer": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "ai-collaboration",
    "human-ai-collaboration",
    "fluently",
    "4d-framework",
    "llm",
    "claude",
    "gpt",
    "gemini",
    "mistral",
    "copilot",
    "delegation",
    "discernment",
    "diligence",
    "knowledge-base",
    "workflow",
    "typescript"
  ],
  "homepage": "https://fluently.ctrl6.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fluently-Org/fluently"
  },
  "bugs": {
    "url": "https://github.com/Fluently-Org/fluently/issues"
  },
  "license": "MIT",
  "author": "Faical Yannick Palingwendé Congo"
}
