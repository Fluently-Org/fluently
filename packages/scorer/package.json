{
  "name": "@fluently/scorer",
  "version": "0.2.0",
  "description": "Shared scoring engine for the Fluently 4D Framework. Validates knowledge YAML against the schema and ranks cycles by keyword similarity for any AI task.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "ai",
    "4d-framework",
    "scoring",
    "knowledge-base",
    "zod",
    "llm",
    "delegation",
    "discernment",
    "workflow"
  ],
  "homepage": "https://fluently.ctrl6.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fluently-Org/fluently"
  },
  "bugs": {
    "url": "https://github.com/Fluently-Org/fluently/issues"
  },
  "license": "MIT",
  "author": "Faical Yannick Palingwend\u00e9 Congo"
