{
  "name": "fluently-scorer",
  "version": "0.2.3",
  "description": "Zero-dependency scoring engine for the Fluently 4D Framework. Validates YAML knowledge cycles with Zod and ranks them by keyword similarity — no API calls, no false-precision scores.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "fluently",
    "4d-framework",
    "ai-collaboration",
    "human-ai-collaboration",
    "scoring",
    "ranking",
    "knowledge-base",
    "yaml",
    "zod",
    "validation",
    "typescript",
    "delegation",
    "discernment",
    "diligence",
    "llm",
    "workflow"
  ],
  "homepage": "https://fluently.ctrl6.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fluently-Org/fluently"
  },
  "bugs": {
    "url": "https://github.com/Fluently-Org/fluently/issues"
  },
  "license": "MIT",
  "author": "Faical Yannick Palingwendé Congo"
}
